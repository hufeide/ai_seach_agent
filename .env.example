# ==============================
# Network proxy
# ==============================
# The startup script scripts/run_api.sh exports these automatically.
HTTP_PROXY=socks5://192.168.1.159:10808
HTTPS_PROXY=socks5://192.168.1.159:10808
NO_PROXY=localhost,127.0.0.1,::1,192.168.0.0/16,10.0.0.0/8

# ==============================
# vLLM OpenAI-compatible API
# Example vLLM server: python -m vllm.entrypoints.openai.api_server --model Qwen/Qwen2.5-7B-Instruct --served-model-name qwen2.5-7b-instruct
# ==============================
VLLM_BASE_URL=http://192.168.1.210:9999/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=Qwen3Coder
VLLM_TIMEOUT_SECONDS=120

# ==============================
# SearXNG
# ==============================
SEARXNG_URL=http://127.0.0.1:18080/search
SEARXNG_TIMEOUT_SECONDS=30

# ==============================
# Crawl4AI
# ==============================
CRAWL_TIMEOUT_SECONDS=45
CRAWL_MAX_CHARS_PER_PAGE=12000
CRAWL_USER_AGENT=Mozilla/5.0 (compatible; AISearchAgent/0.1; +https://example.local/bot)

# ==============================
# Self-hosted BGE vector DB / retrieval service
# This project assumes your BGE DB exposes an HTTP API:
# POST {BGE_DB_BASE_URL}{BGE_DB_UPSERT_PATH}
# POST {BGE_DB_BASE_URL}{BGE_DB_SEARCH_PATH}
# See README.md for exact payloads.
# ==============================
BGE_DB_BASE_URL=http://127.0.0.1:9000
BGE_DB_API_KEY=
BGE_DB_UPSERT_PATH=/upsert
BGE_DB_SEARCH_PATH=/search
BGE_DB_TIMEOUT_SECONDS=60
BGE_DB_ENABLED=true
BGE_DB_COLLECTION=web_search
BGE_DB_TOP_K=8

# ==============================
# Agent behavior
# ==============================
MAX_SEARCH_RESULTS=10
MAX_CRAWL_PAGES=6
MAX_ITERATIONS=2
QUERY_COUNT=4
EVIDENCE_TOP_K=6
